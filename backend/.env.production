# Production environment configuration
# For Docker: Use this as reference; docker-compose.yml will override specific values
# For cloud deployment: Update MONGO_URI and CLIENT_URL accordingly

MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/smartdocs
JWT_SECRET=your-production-secret-key-minimum-32-characters
CLIENT_URL=https://yourdomain.com
PORT=5000
NODE_ENV=production
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
