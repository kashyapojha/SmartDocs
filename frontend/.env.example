# Frontend Environment Configuration Template
# Copy this file to .env and update the values for your environment

# API URL - Points to your backend server
# For local development: http://localhost:5000
# For Docker: http://backend:5000 (backend is the service name in docker-compose.yml)
REACT_APP_API_URL=http://3.111.204.19:5000

# React App Environment
REACT_APP_ENV=development

# Enable detailed logging (development only)
REACT_APP_DEBUG=true
